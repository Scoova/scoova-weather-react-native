{
  "name": "@scoova/weather-react-native",
  "version": "1.1.1",
  "description": "Weather SDK for React Native \u2014 open-meteo compatible client for the Scoova weather gateway. Pure TypeScript, no native modules required. Locale-aware.",
  "main": "lib/typescript/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src/",
    "lib/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "license": "Apache-2.0",
  "author": "Scoova <info@scoo-va.info>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Scoova/scoova-weather-react-native.git"
  },
  "homepage": "https://github.com/Scoova/scoova-weather-react-native",
  "bugs": {
    "url": "https://github.com/Scoova/scoova-weather-react-native/issues"
  },
  "keywords": [
    "scoova",
    "weather",
    "forecast",
    "open-meteo",
    "react-native",
    "sdk"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.74.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
